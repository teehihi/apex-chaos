# Browser-facing URL of the persistent WebSocket room relay.
# Deploy `server/manual-room-relay.js` to a host that supports WebSocket upgrades,
# then point this value at its room route. Do not use the static Vercel frontend URL.
# Leave empty locally. Set the real wss:// Render URL in Vercel's environment settings.
VITE_MANUAL_ROOM_WS_URL=
